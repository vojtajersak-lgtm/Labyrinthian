<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root" prefHeight="576.0" prefWidth="1024.0"
            stylesheets="@CSS/style.css" id="gameOverRoot"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cz.cvut.fel.pjv.labyrinthian.UI.EndScreen">
   <children>
      <VBox alignment="CENTER" layoutX="262.0" layoutY="100.0"
            prefWidth="500.0" spacing="24.0">
         <children>


            <Label fx:id="title" text="GAME OVER"
                   styleClass="endScreenTitle"
                   maxWidth="500.0" wrapText="true" />


            <Label fx:id="stats" text="stats"
                   styleClass="endScreenStats"
                   maxWidth="500.0" wrapText="true" />


            <Label fx:id="messageText"
                   text="Congratulations, you escaped the labyrinth! But after all those years inside, do you really know anything else? Do you even know yourself? The Labyrinth knows you though... you don't want to escape. You want to return, don't you?.."
                   styleClass="endScreenMessage"
                   maxWidth="500.0" wrapText="true"
                   visible="false" managed="false" />

            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false"
                          onAction="#onReturnToMenu"
                          text="Return to menu"
                          styleClass="overSceenButton" />
                  <Button fx:id="continueButton"
                          mnemonicParsing="false"
                          onAction="#onEndlessMode"
                          text="Endless mode"
                          styleClass="overSceenButton"
                          visible="false" managed="false" />
               </children>
            </HBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
