<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane id="pauseMenuRoot" prefHeight="576.0" prefWidth="1024.0" stylesheets="@CSS/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cz.cvut.fel.pjv.labyrinthian.UI.PauseMenuScreen">
    <children>
        <VBox alignment="CENTER" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#onResumeGame" text="Resume Game" />
                <Button mnemonicParsing="false" onAction="#onSaveGame" text="Save Game" />
                <Button mnemonicParsing="false"  onAction="#onMainMenu" text="Quit to main menu" />
            </children>
        </VBox>
    </children>
</StackPane>