<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cz.cvut.fel.pjv.labyrinthian.Core.MainMenuController">
   <children>
      <VBox alignment="CENTER" layoutX="218.0" layoutY="117.0" prefHeight="283.0" prefWidth="165.0" spacing="10.0">
         <children>
            <Button alignment="CENTER" contentDisplay="CENTER" lineSpacing="1.0" mnemonicParsing="false" onAction="#onStartGame" prefHeight="50.0" prefWidth="135.0" text="Start Game" textAlignment="CENTER" textFill="#030303" />
            <Button mnemonicParsing="false" prefHeight="41.0" prefWidth="116.0" text="Load Game" />
            <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="25.0" prefWidth="109.0" text="Settings">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#onExit" text="Exit Game">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Button>
         </children>
         <opaqueInsets>
            <Insets top="1.0" />
         </opaqueInsets>
      </VBox>
      <Label alignment="CENTER" contentDisplay="CENTER" layoutX="120.0" layoutY="-13.0" prefHeight="185.0" prefWidth="360.0" text="LABYRINTHIAN" textAlignment="CENTER">
         <font>
            <Font name="Comic Sans MS" size="37.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
