<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="576.0" prefWidth="1024.0" stylesheets="@CSS/style.css" id="mainMenuRoot" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cz.cvut.fel.pjv.labyrinthian.UI.MainMenuScreen">
   <children>
      <VBox alignment="CENTER" layoutX="440.0" layoutY="180.0" prefHeight="283.0" prefWidth="165.0" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onStartGame" text="Start Game" >
               <VBox.margin><Insets bottom="10.0" /></VBox.margin>
            </Button>
            <Button mnemonicParsing="false" text="Load Game" />
            <Button mnemonicParsing="false" text="Settings">
               <VBox.margin><Insets top="5.0" /></VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#onExit" text="Exit Game">
               <VBox.margin><Insets top="10.0" /></VBox.margin>
            </Button>
         </children>
      </VBox>
      <Label layoutX="300.0" layoutY="10.0" prefHeight="100.0" prefWidth="440.0" text="LABYRINTHIAN" styleClass="titleText" />
   </children>
</AnchorPane>